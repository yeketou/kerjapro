{
  "realm": "kerjapro",
  "displayName": "KerjaPro",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 900,
  "refreshTokenMaxReuse": 0,
  "ssoSessionMaxLifespan": 36000,

  "roles": {
    "realm": [
      { "name": "MAIN_CONTRACTOR", "description": "Enterprise main contractor — has tenant context" },
      { "name": "SUBCONTRACTOR",   "description": "Platform-wide subcontractor — no tenant context" },
      { "name": "PLATFORM_ADMIN",  "description": "KerjaPro platform administrator" }
    ]
  },

  "clients": [
    {
      "clientId": "kerjapro-mobile",
      "name": "KerjaPro Mobile App",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "kerjapro://auth/callback",
        "exp://localhost:8081/--/auth/callback",
        "https://auth.expo.io/@yeketou/kerjapro-mobile"
      ],
      "webOrigins": ["*"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "kerjapro-gateway",
      "name": "KerjaPro Gateway (internal)",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "protocol": "openid-connect",
      "secret": "kerjapro-gateway-secret"
    }
  ],

  "clientScopes": [
    {
      "name": "kerjapro-claims",
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "tenant-slug-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "tenant_slug",
            "claim.name": "tenant_slug",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "realm-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],

  "defaultDefaultClientScopes": [
    "profile", "email", "roles", "kerjapro-claims"
  ],

  "users": [
    {
      "username": "admin@kerjapro.com",
      "email": "admin@kerjapro.com",
      "firstName": "Platform",
      "lastName": "Admin",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "Admin@1234", "temporary": false }],
      "realmRoles": ["PLATFORM_ADMIN"]
    },
    {
      "username": "mc@demo.com",
      "email": "mc@demo.com",
      "firstName": "Demo",
      "lastName": "Contractor",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "Demo@1234", "temporary": false }],
      "realmRoles": ["MAIN_CONTRACTOR"],
      "attributes": { "tenant_slug": ["demo"] }
    },
    {
      "username": "sub@demo.com",
      "email": "sub@demo.com",
      "firstName": "Demo",
      "lastName": "Subcontractor",
      "enabled": true,
      "credentials": [{ "type": "password", "value": "Demo@1234", "temporary": false }],
      "realmRoles": ["SUBCONTRACTOR"]
    }
  ]
}
